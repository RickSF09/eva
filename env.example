# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration
# Create a test account at https://stripe.com and copy the keys here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_123
STRIPE_SECRET_KEY=sk_test_123
STRIPE_WEBHOOK_SECRET=whsec_123

# Stripe Price IDs — Outbound subscription tiers
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PEACE_OF_MIND=price_yyy
NEXT_PUBLIC_STRIPE_PRICE_COMPLETE_CARE=price_zzz

# Stripe Price IDs — Inbound add-on tiers
NEXT_PUBLIC_STRIPE_PRICE_INBOUND_1=price_inbound_1
NEXT_PUBLIC_STRIPE_PRICE_INBOUND_2=price_inbound_2
NEXT_PUBLIC_STRIPE_PRICE_INBOUND_3=price_inbound_3

# Stripe Product ID — Overage (used for invoice line items)
STRIPE_OVERAGE_PRODUCT_ID=prod_overage

# Internal API key (for backend → frontend internal endpoints)
INTERNAL_API_KEY=

# Trial, grace period, and overage rates are configured in src/config/plans.ts

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_ADMIN_EMAILS=ops@example.com

# For local development, create a .env.local file with your actual values
# Copy this file to .env.local and replace the values above
